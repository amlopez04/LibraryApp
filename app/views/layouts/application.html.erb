<!DOCTYPE html>
<html>
  <head>
    <title>Library App</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" /> <!-- important -->
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>
  <body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <%= link_to "Library", root_path, class: "navbar-brand" %>

        <!-- mobile toggle button -->
        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <!-- collapsible area -->
        <div class="collapse navbar-collapse justify-content-end" id="mainNav">
          <ul class="navbar-nav ms-auto mb-2 mb-lg-0 w-100 text-end">
            <li class="nav-item"><%= nav_link "Books",   books_path %></li>
            <li class="nav-item"><%= nav_link "Authors", authors_path %></li>
            <li class="nav-item"><%= nav_link "Genres",  genres_path %></li>
          </ul>

          
        </div>
      </div>
    </nav>

    <div class="container">
      <% flash.each do |k,v| %>
        <div class="alert <%= k.to_s == "notice" ? "alert-success" : "alert-warning" %>"><%= v %></div>
      <% end %>
      <%= yield %>
    </div>

    <!-- Bootstrap JS (enables the collapse) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Optional: auto-close the mobile menu after clicking a link (works with Turbo) -->
    <script>
      document.addEventListener("turbo:load", () => {
        const nav = document.getElementById("mainNav");
        if (!nav) return;
        nav.querySelectorAll("a.nav-link").forEach(link => {
          link.addEventListener("click", () => {
            const bs = bootstrap.Collapse.getInstance(nav) || new bootstrap.Collapse(nav, {toggle: false});
            bs.hide();
          });
        });
      });
    </script>
  </body>
</html>
