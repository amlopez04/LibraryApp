<div class="bg-white p-4 rounded shadow-sm">
  <h1>Review</h1>
  <p><strong>Book:</strong> <%= link_to @review.book.title, book_path(@review.book) %></p>
  <p><strong>Reviewer:</strong> <%= @review.reviewer_name %></p>
  <p><strong>Rating:</strong> <%= @review.rating %>/5</p>
  <p><%= simple_format @review.body %></p>
  <div class="d-flex gap-2">
    <%= link_to "Edit", edit_review_path(@review), class: "btn btn-outline-secondary" %>
    <%= link_to "Back to Book", book_path(@review.book), class: "btn btn-light" %>
  </div>
</div>
