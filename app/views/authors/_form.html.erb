<%= render "shared/errors", object: author %>
<%= form_with model: author,
              url: author.persisted? ? author_path(author) : authors_path,
              method: author.persisted? ? :patch : :post,
              class: "row g-3" do |f| %>
  <div class="col-md-6">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true %>
  </div>
  <div class="col-md-6">
    <%= f.label :email, class: "form-label" %>
    <%= f.email_field :email, class: "form-control" %>
  </div>
  <div class="col-12">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", author.persisted? ? author_path(author) : authors_path, class: "btn btn-light" %>
  </div>
<% end %>
