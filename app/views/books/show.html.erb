<div class="bg-white p-4 rounded shadow-sm mb-3">
  <h1 class="mb-2"><%= @book.title %></h1>
  <p class="text-muted">By <%= @book.author.name %> — <span class="badge bg-secondary"><%= @book.genre.name %></span></p>
  <hr>
  <%= simple_format @book.description %>
  <div class="mt-3 d-flex gap-2">
    <%= link_to "Edit", edit_book_path(@book), class: "btn btn-outline-secondary" %>
    <%= button_to "Delete", book_path(@book), 
    method: :delete,
    class: "btn btn-outline-danger",
    data: { turbo_confirm: "Delete this book?" } %>
    <%= link_to "Back", books_path, class: "btn btn-light" %>
  </div>
</div>

<h3>Reviews</h3>
<p>
  <%= link_to "All Reviews", book_reviews_path(book_id: @book.id), class: "btn btn-sm btn-outline-primary" %>
  <%= link_to "New Review",  new_book_review_path(book_id: @book.id), class: "btn btn-sm btn-primary" %>
</p>
