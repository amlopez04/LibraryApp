<%= render "shared/errors", object: @book %>
<%= form_with model: @book,
              url: @book.persisted? ? book_path(@book) : books_path,
              method: @book.persisted? ? :patch : :post,
              class: "row g-3" do |f| %>
  <div class="col-12">
    <%= f.label :title, class: "form-label" %>
    <%= f.text_field :title, class: "form-control", required: true %>
  </div>
  <div class="col-12">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, rows: 4, class: "form-control" %>
  </div>
  <div class="col-md-6">
    <%= f.label :author_id, "Author", class: "form-label" %>
    <%= f.collection_select :author_id, @authors,
          :id, :name, { include_blank: "Select author" }, { class: "form-select" } %>
  </div>
  <div class="col-md-6">
    <%= f.label :genre_id, "Genre", class: "form-label" %>
    <%= f.collection_select :genre_id, @genres,
          :id, :name, { include_blank: "Select genre" }, { class: "form-select" } %>
  </div>
  <div class="col-12">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", @book.persisted? ? book_path(@book) : books_path, class: "btn btn-light" %>
  </div>
<% end %>
