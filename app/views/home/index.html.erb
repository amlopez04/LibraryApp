<div class="p-4 bg-white rounded shadow-sm">
  <h1 class="mb-3">Welcome to the Library</h1>
  <p class="text-muted">Quick create</p>

  <div class="row g-2 mb-3">
    <div class="col-sm-4"><%= link_to "New Book",   new_book_path,   class: "btn btn-primary w-100" %></div>
    <div class="col-sm-4"><%= link_to "New Author", new_author_path, class: "btn btn-primary w-100" %></div>
    <div class="col-sm-4"><%= link_to "New Genre",  new_genre_path,  class: "btn btn-primary w-100" %></div>
  </div>

  <hr>

  <div class="row text-center mb-3">
    <div class="col">
      <div class="p-3 bg-light rounded">
        <div class="h2"><%= @counts[:books] %></div><div class="text-muted">Books</div>
      </div>
    </div>
    <div class="col">
      <div class="p-3 bg-light rounded">
        <div class="h2"><%= @counts[:authors] %></div><div class="text-muted">Authors</div>
      </div>
    </div>
    <div class="col">
      <div class="p-3 bg-light rounded">
        <div class="h2"><%= @counts[:genres] %></div><div class="text-muted">Genres</div>
      </div>
    </div>
  </div>

  <h4>Latest Books</h4>
  <ul class="list-group">
    <% @books.each do |b| %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <span>
          <%= link_to b.title, book_path(b) %>
          <span class="badge bg-secondary ms-2"><%= b.genre.name %></span>
        </span>
        <small class="text-muted"><%= b.author.name %></small>
      </li>
    <% end %>
  </ul>

  <hr class="my-4">
  <p>Browse lists:</p>
  <div class="d-flex gap-2">
    <%= link_to "Books", books_path, class: "btn btn-outline-primary" %>
    <%= link_to "Authors", authors_path, class: "btn btn-outline-primary" %>
    <%= link_to "Genres", genres_path, class: "btn btn-outline-primary" %>
  </div>
</div>
